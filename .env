# ========== MONGODB CONFIGURATION ==========
# Production MongoDB Atlas - LolCluster
# Connection string includes credentials, connection pooling, and app name
MONGODB_URI=mongodb+srv://overx:ankit5639@lolcluster.68fu58k.mongodb.net/lolcluster?appName=lolcluster

# ========== SERVER CONFIGURATION ==========
# Server port
PORT=8080

# Server IP (advertised to clients)
SERVER_IP=127.0.0.1

# Server bind address (0.0.0.0 = all interfaces)
SERVER_BIND=0.0.0.0

# ========== OPTIONAL: TURN SERVER (for WebRTC) ==========
# Uncomment and configure if using external TURN server
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=password

# ========== NODE ENVIRONMENT ==========
# development | production | staging
NODE_ENV=development
